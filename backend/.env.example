NODE_ENV=development
PORT=3001
USE_PGMEM=true
DATABASE_URL=postgres://postgres:postgres@localhost:5432/eduskill
JWT_SECRET=change-me-super-long-secret
ACCESS_TOKEN_EXPIRES_IN=15m
ACCESS_TOKEN_SECONDS=900
REFRESH_TOKEN_DAYS=7
ALLOWED_ORIGINS=http://127.0.0.1:5500,http://localhost:5500,http://127.0.0.1:8080,http://localhost:8080
LOGIN_WINDOW_MS=300000
LOGIN_MAX_ATTEMPTS=7
